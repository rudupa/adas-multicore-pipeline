  "ecus": [
    {
      "name": "compute_ecu_main",
      "role": "central_compute_ecu",
      "hosts": [
        "all_6_cameras",
        "all_radar_outputs",
        "imu",
        "wheel_odometry",
        "gnss"
      ],
      "responsibilities": [
        "time_sync_and_snapshot_build",
        "camera_preprocessing",
        "object_detection",
        "lane_and_road_detection",
        "semantic_segmentation",
        "depth_estimation_optional",
        "camera_tracking_optional",
        "fusion_spatial_alignment",
        "fusion_temporal_alignment",
        "fusion_data_association",
        "fusion_state_fusion",
        "fusion_track_management",
        "environment_model_build",
        "ego_motion_estimation",
        "gnss_integration",
        "map_matching",
        "pose_estimation",
        "prediction_input_aggregation",
        "kinematic_prediction",
        "interaction_prediction",
        "uncertainty_modeling",
        "behavior_planning",
        "trajectory_planning"
      ]
    }
  ],
  "real_time_execution_view": {
    "sense": {
      "1.1_camera_processing": {
        "execution_model": "parallel_per_camera_plus_pipelined_over_frames",
        "placement": "compute_ecu_main",
        "sub_steps": [
          "1.1.1_preprocessing",
          "1.1.2_object_detection",
          "1.1.3_lane_and_road_detection",
          "1.1.4_semantic_segmentation",
          "1.1.5_depth_estimation_optional",
          "1.1.6_camera_tracking_optional"
        ]
      },
      "1.2_radar_processing": {
        "execution_model": "sequential_per_radar_cycle_parallel_across_radars",
        "placement": "compute_ecu_main",
        "sub_steps": [
          "1.2.1_signal_processing",
          "1.2.2_cfar_detection",
          "1.2.3_clustering",
          "1.2.4_ego_motion_compensation",
          "1.2.5_radar_tracking"
        ]
      },
      "1.3_sensor_acquisition": {
        "execution_model": "parallel",
        "sub_steps": [
          "1.3.1_camera_capture",
          "1.3.2_radar_capture",
          "1.3.3_vehicle_state_capture",
          "1.3.4_time_sync_on_consume"
        ],
        "placement": {
          "camera_capture": "camera_devices_to_camera_ingress",
          "radar_capture": "radar_devices_to_radar_ingress",
          "vehicle_state_capture": "compute_ecu_main",
          "time_sync_on_consume": "compute_ecu_main"
        }
      },
      "1.4_fusion": {
        "execution_model": "periodic_snapshot_based",
        "placement": "compute_ecu_main",
        "sub_steps": [
          "1.4.1_spatial_alignment",
          "1.4.2_temporal_alignment",
          "1.4.3_data_association",
          "1.4.4_state_fusion",
          "1.4.5_track_management",
          "1.4.6_environment_model"
        ]
      },
      "1.5_localization": {
        "execution_model": "continuous_high_rate_with_lower_rate_gnss",
        "placement": "compute_ecu_main",
        "sub_steps": [
          "1.5.1_ego_motion_estimation",
          "1.5.2_gnss_integration",
          "1.5.3_map_matching",
          "1.5.4_pose_estimation"
        ]
      },
      "1.6_world_map_build": {
        "execution_model": "serial_per_cycle",
        "placement": "compute_ecu_main",
        "sub_steps": [
          "1.6.1_grid_update",
          "1.6.2_semantic_layer_fusion",
          "1.6.3_drivable_area_update"
        ]
      }
    },
    "plan": {
      "2.1_prediction": {
        "execution_model": "periodic_per_planning_cycle",
        "placement": "compute_ecu_main",
        "sub_steps": [
          "2.1.1_input_aggregation",
          "2.1.2_kinematic_prediction",
          "2.1.3_interaction_prediction",
          "2.1.4_uncertainty_modeling",
          "2.1.5_predicted_trajectories"
        ]
      },
      "2.2_behavior_planning": {
        "execution_model": "sequential_decision_step",
        "placement": "compute_ecu_main",
        "sub_steps": [
          "2.2.1_situation_assessment",
          "2.2.2_rule_evaluation",
          "2.2.3_risk_assessment",
          "2.2.4_maneuver_selection",
          "2.2.5_goal_setting"
        ]
      },
      "2.3_trajectory_planning": {
        "execution_model": "optimization_loop",
        "placement": "compute_ecu_main",
        "sub_steps": [
          "2.3.1_constraints_setup",
          "2.3.2_path_planning",
          "2.3.3_speed_planning",
          "2.3.4_coupled_optimization",
          "2.3.5_final_trajectory",
          "2.3.6_trajectory_plausibility_check"
        ]
      },
      "2.4_trajectory_plausibility_check": {
        "execution_model": "sequential_safety_gate",
        "placement": "compute_ecu_main",
        "sub_steps": [
          "2.4.1_dynamic_constraint_check",
          "2.4.2_collision_risk_screen",
          "2.4.3_fallback_trajectory_selection"
        ]
      }
    },
    "act": {
      "3.1_control": {
        "execution_model": "high_rate_control_loops",
        "placement": "compute_ecu_main",
        "sub_steps": [
          "3.1.1_lateral_control",
          "3.1.2_longitudinal_control",
          "3.1.3_actuator_commands"
        ]
      },
      "3.2_feedback": {
        "execution_model": "continuous_monitoring",
        "placement": "compute_ecu_main",
        "sub_steps": [
          "3.2.1_state_monitoring",
          "3.2.2_error_correction",
          "3.2.3_safety_supervision"
        ]
      }
    }
  },
